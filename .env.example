# ============================================================
# Maios Shop – Environment-Vorlage (ROOT / Backend)
# Kopieren:  cp .env.example .env   und mit echten Werten füllen.
# .env selbst NIEMALS committen (siehe .gitignore).
# ============================================================

# ── Laufzeit ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=localhost
SITE_URL=https://maiosshop.com
REPL_URL=
DOMAIN=
SUBDOMAIN=
FULL_URL=

# ── Stripe (SECRET – rotieren falls je geleakt) ──────────────
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
CJ_STRIPE_ACCOUNT_ID=

# ── CJ Dropshipping (SECRET) ─────────────────────────────────
CJ_API_BASE_URL=https://developers.cjdropshipping.com
CJ_API_KEY=
CJ_API_SECRET=
CJ_ACCESS_TOKEN=
CJ_REFRESH_TOKEN=
CJ_WAREHOUSE_DE=
CJ_WAREHOUSE_EU=
CJ_WAREHOUSE_US=

# ── E-Mail: Resend (SECRET) ──────────────────────────────────
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@maiosshop.com
RESEND_FROM_NAME=Maios
FROM_EMAIL=
FROM_NAME=
SUPPORT_EMAIL=
ADMIN_EMAIL=

# ── E-Mail: SMTP-Fallback (SECRET) ───────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Wechselkurse ─────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=

# ── Sicherheit / Sessions (SECRET – zufällig generieren) ─────
SESSION_SECRET=
JWT_SECRET=
ENCRYPTION_KEY=
# Admin-Login (HTTP Basic Auth für Dashboards + /api/cj + Admin-/api/receipt-Routen)
ADMIN_USER=admin
ADMIN_PASSWORD=
ADMIN_PANEL_PATH=

# ── Datenbank (aktuell SQLite lokal; diese Felder ungenutzt) ─
DATABASE_URL=
DB_NAME=
DB_USER=
DB_PASSWORD=

# ── Versand / Shop-Defaults ──────────────────────────────────
FREE_SHIPPING_THRESHOLD=50
SHIPPING_COST_EUROPE=4.99
SHIPPING_COST_INTERNATIONAL=9.99
DELIVERY_TIME_STANDARD=3-5
DELIVERY_TIME_EXPRESS=1-2
DEFAULT_CURRENCY=EUR
DEFAULT_LANGUAGE=de
TIMEZONE=Europe/Berlin

# ── Firmendaten (Impressum/Beleg) ────────────────────────────
COMPANY_NAME=
COMPANY_ADDRESS=
COMPANY_CITY=
COMPANY_COUNTRY=
COMPANY_PHONE=
COMPANY_TAX_ID=

# ── Analytics / Marketing (SECRET wo Token) ──────────────────
GA_TRACKING_ID=
FB_PIXEL_ID=
FACEBOOK_APP_ID=
INSTAGRAM_ACCESS_TOKEN=
TWITTER_API_KEY=
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
GOOGLE_MAPS_API_KEY=

# ── Uploads / Bilder ─────────────────────────────────────────
MAX_FILE_SIZE=
ALLOWED_FILE_TYPES=
UPLOAD_PATH=
IMAGE_QUALITY=
IMAGE_MAX_WIDTH=
IMAGE_MAX_HEIGHT=
THUMBNAIL_SIZE=

# ── Cache / Logging / Monitoring ─────────────────────────────
REDIS_URL=
CACHE_TTL=
LOG_LEVEL=info
LOG_FILE=
DEBUG=false
VERBOSE_LOGGING=false
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=

# ── CORS / HTTPS / Betrieb ───────────────────────────────────
ENABLE_CORS=true
CORS_ORIGIN=https://maiosshop.com
FORCE_HTTPS=true
SSL_CERT_PATH=
SSL_KEY_PATH=
MAINTENANCE_MODE=false
RATE_LIMIT_WINDOW=
RATE_LIMIT_MAX_REQUESTS=
BACKUP_SCHEDULE=
BACKUP_RETENTION_DAYS=

# ── Webhooks (intern) ────────────────────────────────────────
WEBHOOK_ORDER_CREATED=
WEBHOOK_PAYMENT_SUCCESS=
WEBHOOK_SHIPPING_UPDATE=

# ── Lokale Video-/TikTok-Render-Defaults (auch in Marketing) ─
VIDEO_RENDER_BACKEND=
LOCAL_VIDEO_DEVICE=
LOCAL_VIDEO_MODEL_ID=
LOCAL_VIDEO_STEPS=
LOCAL_VIDEO_GUIDANCE=
LOCAL_VIDEO_FRAMES=
TIKTOK_CHROMEDRIVER=
TIKTOK_CHROME_PROFILE=
